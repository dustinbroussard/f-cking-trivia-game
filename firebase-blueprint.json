{
  "entities": {
    "Game": {
      "title": "Game",
      "description": "A trivia game session.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "4-digit join code" },
        "status": { "type": "string", "enum": ["waiting", "active", "completed"] },
        "hostId": { "type": "string" },
        "playerIds": { "type": "array", "items": { "type": "string" } },
        "currentTurn": { "type": "string", "description": "UID of the player whose turn it is" },
        "winnerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "status", "hostId", "playerIds", "createdAt"]
    },
    "Player": {
      "title": "Player",
      "description": "A player in a game.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "score": { "type": "integer" },
        "streak": { "type": "integer" },
        "completedCategories": { "type": "array", "items": { "type": "string" } },
        "avatarUrl": { "type": "string" }
      },
      "required": ["uid", "name", "score", "streak", "completedCategories"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A chat message in a game lobby.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["uid", "name", "text", "timestamp"]
    },
    "Question": {
      "title": "Question",
      "description": "A trivia question that can be reused globally or assigned to a game.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "questionId": { "type": "string", "description": "Reference to the canonical bank question" },
        "category": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "question": { "type": "string" },
        "choices": { "type": "array", "items": { "type": "string" } },
        "correctIndex": { "type": "integer" },
        "answerIndex": { "type": "integer" },
        "explanation": { "type": "string" },
        "validationStatus": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "integer" },
        "usedCount": { "type": "integer" },
        "correctQuip": { "type": "string" },
        "wrongAnswerQuips": { "type": "object" },
        "used": { "type": "boolean" }
      },
      "required": ["category", "difficulty", "question", "choices", "correctIndex", "answerIndex", "explanation", "validationStatus", "createdAt", "usedCount", "correctQuip", "wrongAnswerQuips", "used"]
    },
    "UserSettings": {
      "title": "UserSettings",
      "description": "Persisted user preferences for theme, audio, and commentary.",
      "type": "object",
      "properties": {
        "themeMode": { "type": "string", "enum": ["dark", "light"] },
        "soundEnabled": { "type": "boolean" },
        "musicEnabled": { "type": "boolean" },
        "sfxEnabled": { "type": "boolean" },
        "commentaryEnabled": { "type": "boolean" },
        "updatedAt": { "type": "integer" }
      },
      "required": ["themeMode", "soundEnabled", "musicEnabled", "sfxEnabled", "commentaryEnabled", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{uid}/private/settings": {
      "schema": "UserSettings",
      "description": "Private per-user settings synced across devices"
    },
    "/questionBank/{questionId}": {
      "schema": "Question",
      "description": "Canonical reusable global trivia questions"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Main game document"
    },
    "/games/{gameId}/players/{playerId}": {
      "schema": "Player",
      "description": "Players in the game"
    },
    "/games/{gameId}/questions/{questionId}": {
      "schema": "Question",
      "description": "Questions for this game"
    },
    "/games/{gameId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages in the game lobby"
    }
  }
}
