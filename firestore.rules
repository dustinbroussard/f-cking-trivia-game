rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Firestore rules do not cascade to subcollections.
    // Every subcollection path used by the app must be matched explicitly.
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /games/{gameId} {
      allow create, read, update: if isAuthenticated();

      match /players/{playerId} {
        allow read, write: if isAuthenticated();
      }

      match /questions/{questionId} {
        allow read, write: if isAuthenticated();
      }

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /questions/{questionId} {
      allow read, write: if isAuthenticated();
    }

    match /flaggedQuestions/{flagId} {
      allow read, write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /private/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /recentPlayers/{otherUid} {
        allow read, write: if isOwner(userId);
      }

      match /seenQuestions/{questionId} {
        allow read, write: if isOwner(userId);
      }

      match /invites/{inviteId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isAuthenticated()
          && request.resource.data.toUid == userId
          && request.resource.data.fromUid == request.auth.uid;
      }
    }
  }
}
